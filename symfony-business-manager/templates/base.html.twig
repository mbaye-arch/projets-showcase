<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Symfony Business Manager{% endblock %}</title>
    <style>
      body {
        margin: 0;
        color: #15202b;
        background: #f4f6f8;
        font-family: Inter, Arial, Helvetica, sans-serif;
      }

      a {
        color: inherit;
      }

      .shell {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        padding: 28px 0;
      }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        margin-bottom: 24px;
      }

      .nav div {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
      }

      .nav a {
        color: #245b70;
        font-weight: 700;
        text-decoration: none;
      }

      .hero {
        padding: 30px;
        color: #ffffff;
        background: #245b70;
        border-radius: 8px;
      }

      .hero h1 {
        margin: 0 0 10px;
      }

      .hero p {
        max-width: 720px;
        margin: 0;
        color: #ecf5f8;
        line-height: 1.5;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        margin-top: 18px;
      }

      .card {
        min-height: 110px;
        padding: 18px;
        background: #ffffff;
        border: 1px solid #d8e1e6;
        border-radius: 8px;
      }

      .card span {
        color: #5c6b76;
      }

      .card strong {
        display: block;
        margin: 8px 0;
        color: #173b49;
        font-size: 26px;
      }

      .panel {
        margin-top: 22px;
      }

      .panel h2 {
        margin: 0 0 12px;
        font-size: 20px;
      }

      table {
        width: 100%;
        margin-top: 18px;
        background: #ffffff;
        border-collapse: collapse;
        border: 1px solid #d8e1e6;
        border-radius: 8px;
        overflow: hidden;
      }

      th,
      td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #d9e2e6;
      }

      th {
        color: #5c6b76;
        font-size: 12px;
        text-transform: uppercase;
      }

      .badge {
        display: inline-block;
        padding: 4px 8px;
        color: #ffffff;
        background: #245b70;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
      }

      .badge.paid,
      .badge.active {
        background: #24815d;
      }

      .badge.pending {
        background: #9b6a19;
      }

      .badge.late,
      .badge.inactive {
        background: #a33d3d;
      }

      @media (max-width: 760px) {
        .nav {
          align-items: flex-start;
          flex-direction: column;
        }

        .grid {
          grid-template-columns: 1fr 1fr;
        }

        table {
          display: block;
          overflow-x: auto;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <nav class="nav">
        <strong>Business Manager</strong>
        <div>
          <a href="{{ path('app_dashboard') }}">Dashboard</a>
          <a href="{{ path('app_client_index') }}">Clients</a>
          <a href="{{ path('app_service_offer_index') }}">Prestations</a>
          <a href="{{ path('app_invoice_index') }}">Factures</a>
        </div>
      </nav>
      {% block body %}{% endblock %}
    </main>
  </body>
</html>
